<script>
  // ---- logo injection (replace the data URI below with your own if you host the file) ----
  var LOGO = "data:image/png;base64,";
  document.getElementById('navlogo').src = LOGO;
  document.getElementById('herologo').src = LOGO;

  // ---- language toggle (Hebrew default) ----
  function toggleLang(){
    var en = document.body.getAttribute('dir') === 'ltr';
    if(en){
      document.body.setAttribute('dir','rtl');
      document.documentElement.lang='he';
      document.getElementById('langBtn').textContent='EN';
      document.getElementById('email').setAttribute('placeholder','האימייל שלך');
    } else {
      document.body.setAttribute('dir','ltr');
      document.documentElement.lang='en';
      document.getElementById('langBtn').textContent='עב';
      document.getElementById('email').setAttribute('placeholder','Your email');
    }
  }
  document.getElementById('email').setAttribute('placeholder','האימייל שלך');

  // ---- waitlist: Formspree (primary, emails you) + Firebase (your own copy) ----
  var FORMSPREE_ENDPOINT = "https://formspree.io/f/xbdenwvk";

  async function joinWaitlist(e){
    e.preventDefault();
    var note = document.getElementById('waitNote');
    var btn  = e.target.querySelector('button');
    var en   = document.body.getAttribute('dir')==='ltr';
    var email = document.getElementById('email').value.trim();
    if(!email) return false;

    btn.disabled = true; btn.style.opacity = '.6';
    note.style.color = "var(--ink-soft)";
    note.textContent = en ? "Sending…" : "שולח…";

    var lang = en ? 'en' : 'he';
    var ok = false;

    // 1) Formspree — emails you every signup
    try{
      var res = await fetch(FORMSPREE_ENDPOINT, {
        method:"POST",
        headers:{ "Accept":"application/json", "Content-Type":"application/json" },
        body: JSON.stringify({ email: email, language: lang, _subject: "New Mekapele waitlist signup" })
      });
      ok = res.ok;
    }catch(err){ console.warn("Formspree failed:", err); }

    // 2) Firebase Firestore — your own database copy
    if(window.saveToFirebase){ try{ var fb = await window.saveToFirebase(email, lang); ok = ok || fb; }catch(_){} }

    btn.disabled = false; btn.style.opacity = '1';

    if(ok){
      note.innerHTML = en ? "🎉 You're on the list! We'll be in touch."
                          : "🎉 נרשמת! נהיה בקשר בקרוב.";
      note.style.color = "var(--sage)";
      document.getElementById('email').value='';
    } else {
      note.innerHTML = en ? "Something went wrong — please try again."
                          : "משהו השתבש — נסו שוב.";
      note.style.color = "var(--rust)";
    }
    return false;
  }
  window.toggleLang = toggleLang;
  window.joinWaitlist = joinWaitlist;
</script>

<script type="module">
  // ============================================================
  //  FIREBASE — paste the two values marked PASTE_… below.
  //  Where to get them: Firebase console → click the gear ⚙ →
  //  Project settings → scroll to "Your apps".
  //  If you have NO web app yet, click the </> (Web) icon, give it
  //  a nickname (e.g. "mekapele-web"), skip hosting, and register.
  //  Then choose "Config" and copy apiKey and appId here.
  //  (These values are safe to expose in public client code.)
  // ============================================================
  import { initializeApp } from "https://www.gstatic.com/firebasejs/11.0.2/firebase-app.js";
  import { getFirestore, collection, addDoc, serverTimestamp }
    from "https://www.gstatic.com/firebasejs/11.0.2/firebase-firestore.js";

  const firebaseConfig = {
    apiKey: "PASTE_API_KEY",
    authDomain: "mekapele.firebaseapp.com",
    projectId: "mekapele",
    storageBucket: "mekapele.firebasestorage.app",
    messagingSenderId: "99434525959",
    appId: "PASTE_APP_ID"
  };

  let db = null;
  try{
    if(firebaseConfig.apiKey !== "PASTE_API_KEY"){
      const app = initializeApp(firebaseConfig);
      db = getFirestore(app);
    }
  }catch(err){ console.warn("Firebase not initialised:", err); }

  window.saveToFirebase = async function(email, lang){
    if(!db) return false;                 // config not filled in yet
    try{
      await addDoc(collection(db, "waitlist"), {
        email: email, lang: lang,
        createdAt: serverTimestamp(), source: "landing"
      });
      return true;
    }catch(err){ console.warn("Firestore write failed:", err); return false; }
  };
</script>
